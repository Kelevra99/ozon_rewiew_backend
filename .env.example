DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ozon_auto_reply?schema=public"
PORT=4000
JWT_SECRET="change_me_please"
BCRYPT_SALT_ROUNDS=10
OPENAI_API_KEY=""
BILLING_MARKUP_MULTIPLIER=1.6

# OpenAI models / tier defaults
OPENAI_MODEL_STANDARD="gpt-5.4-nano"
OPENAI_MODEL_ADVANCED="gpt-5.4-mini"
OPENAI_MODEL_EXPERT="gpt-5.4"
OPENAI_PRICE_STANDARD_INPUT_PER_1M=0.20
OPENAI_PRICE_STANDARD_OUTPUT_PER_1M=1.25
OPENAI_PRICE_STANDARD_CACHED_INPUT_PER_1M=0.02
OPENAI_PRICE_ADVANCED_INPUT_PER_1M=0.75
OPENAI_PRICE_ADVANCED_OUTPUT_PER_1M=4.50
OPENAI_PRICE_ADVANCED_CACHED_INPUT_PER_1M=0.075
OPENAI_PRICE_EXPERT_INPUT_PER_1M=2.50
OPENAI_PRICE_EXPERT_OUTPUT_PER_1M=15.00
OPENAI_PRICE_EXPERT_CACHED_INPUT_PER_1M=0.25

# Payment return URLs
PAYMENT_SUCCESS_URL="http://localhost:3000/billing/topup/success"
PAYMENT_FAIL_URL="http://localhost:3000/billing/topup/fail"

# Ozon acquiring integration
OZON_ACQUIRING_TOKEN_ID=""
OZON_ACQUIRING_ACCESS_KEY=""
OZON_ACQUIRING_SECRET_KEY=""
OZON_ACQUIRING_NOTIFICATION_SECRET=""
OZON_ACQUIRING_API_BASE_URL=""
OZON_ACQUIRING_CREATE_PATH=""
# or set a full direct URL instead of base+path
OZON_ACQUIRING_CREATE_URL=""
OZON_ACQUIRING_TOKEN_HEADER="X-Token-Id"
OZON_ACQUIRING_ACCESS_KEY_HEADER="X-Access-Key"
OZON_ACQUIRING_SECRET_HEADER="X-Secret-Key"
OZON_ACQUIRING_SIGNATURE_HEADER="X-Signature"
